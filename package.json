{
  "name": "@openclawHQ/security-audit",
  "version": "0.1.0",
  "description": "Security audit CLI for OpenClaw configurations. Detects common misconfigurations in 135K+ exposed instances.",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "openclaw-audit": "bin/openclaw-audit.js"
  },
  "scripts": {
    "test": "node --test tests/**/*.test.js",
    "test:watch": "node --watch --test tests/**/*.test.js",
    "lint": "eslint src/ bin/ tests/",
    "format": "prettier --write \"src/**/*.js\" \"bin/**/*.js\" \"tests/**/*.js\"",
    "start": "node bin/openclaw-audit.js"
  },
  "keywords": [
    "openclaw",
    "security",
    "audit",
    "scanner",
    "configuration",
    "security-hardening",
    "misconfigurations",
    "cli",
    "devops"
  ],
  "author": "OpenClawHQ Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenClawHQ/security-toolkit"
  },
  "bugs": {
    "url": "https://github.com/OpenClawHQ/security-toolkit/issues"
  },
  "homepage": "https://github.com/OpenClawHQ/security-toolkit#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {},
  "optionalDependencies": {}
}
